  ],
  "annotations": {"list": []},
  "description": "ARCHIVIRT — IDS/IPS Testing Framework Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "ARCHIVIRT — Overview",
      "type": "row"
    },
    {
      "datasource": {"type": "influxdb", "uid": "archivirt-influx"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 80}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "title": "Monitor VM CPU",
      "type": "stat",
      "targets": [
        {
          "query": "from(bucket: \"archivirt-metrics\") |> range(start: -5m) |> filter(fn: (r) => r[\"_measurement\"] == \"cpu\" and r[\"_field\"] == \"usage_user\" and r[\"host\"] == \"archivirt-monitor-ids\") |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "influxdb", "uid": "archivirt-influx"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 400},
              {"color": "red", "value": 700}
            ]
          },
          "unit": "decmbytes"
        }
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Monitor VM RAM",
      "type": "stat",
      "targets": [
        {
          "query": "from(bucket: \"archivirt-metrics\") |> range(start: -5m) |> filter(fn: (r) => r[\"_measurement\"] == \"mem\" and r[\"_field\"] == \"used\" and r[\"host\"] == \"archivirt-monitor-ids\") |> map(fn: (r) => ({r with _value: r._value / 1048576})) |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "influxdb", "uid": "archivirt-influx"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "id": 4,
      "options": {"colorMode": "background"},
      "title": "Suricata Total Alerts",
      "type": "stat",
      "targets": [
        {
          "query": "from(bucket: \"archivirt-metrics\") |> range(start: -1h) |> filter(fn: (r) => r[\"_measurement\"] == \"archivirt_suricata_alerts\") |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "influxdb", "uid": "archivirt-influx"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "id": 5,
      "options": {"colorMode": "background"},
      "title": "Snort Total Alerts",
      "type": "stat",
      "targets": [
        {
          "query": "from(bucket: \"archivirt-metrics\") |> range(start: -1h) |> filter(fn: (r) => r[\"_measurement\"] == \"archivirt_snort_alerts\") |> last()",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "influxdb", "uid": "archivirt-influx"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}, "unit": "percent"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 5},
      "id": 10,
      "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "title": "CPU Usage — All ARCHIVIRT VMs",
      "type": "timeseries",
      "targets": [
        {
          "query": "from(bucket: \"archivirt-metrics\") |> range(start: -30m) |> filter(fn: (r) => r[\"_measurement\"] == \"cpu\" and r[\"_field\"] == \"usage_user\" and r[\"cpu\"] == \"cpu-total\") |> aggregateWindow(every: 10s, fn: mean)",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "influxdb", "uid": "archivirt-influx"},
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}, "color": {"mode": "palette-classic"}, "unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 5},
      "id": 11,
      "title": "IDS Alerts Over Time",
      "type": "timeseries",
      "targets": [
        {
          "query": "from(bucket: \"archivirt-metrics\") |> range(start: -1h) |> filter(fn: (r) => r[\"_measurement\"] == \"archivirt_suricata_alerts\" or r[\"_measurement\"] == \"archivirt_snort_alerts\") |> aggregateWindow(every: 30s, fn: last)",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
