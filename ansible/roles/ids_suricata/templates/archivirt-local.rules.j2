
# ---------------------------------------------------------
# ARCHIVIRT Local Suricata 6 Rules
# ---------------------------------------------------------
# Port Scan Detection (Nmap)
alert tcp any any -> $HOME_NET any (msg:"ARCHIVIRT Nmap SYN Scan"; flags:S,12; threshold:type threshold, track by_src, count 20, seconds 2; classtype:network-scan; sid:2000001; rev:2;)
alert tcp any any -> $HOME_NET any (msg:"ARCHIVIRT Nmap NULL Scan"; flags:0; sid:2000002; rev:2;)
alert tcp any any -> $HOME_NET any (msg:"ARCHIVIRT Nmap FIN Scan"; flags:F; sid:2000003; rev:2;)
alert tcp any any -> $HOME_NET any (msg:"ARCHIVIRT Nmap XMAS Scan"; flags:FPU; sid:2000004; rev:2;)
alert udp any any -> $HOME_NET any (msg:"ARCHIVIRT Nmap UDP Scan"; threshold:type threshold, track by_src, count 50, seconds 5; sid:2000005; rev:2;)

# SSH Brute-force Detection (Hydra)
alert tcp any any -> $SSH_SERVERS $SSH_PORTS (msg:"ARCHIVIRT SSH Brute-force"; flow:to_server,established; content:"SSH"; threshold:type both, track by_src, count 5, seconds 30; classtype:attempted-user; sid:2000010; rev:2;)
alert tcp any any -> $SSH_SERVERS $SSH_PORTS (msg:"ARCHIVIRT SSH Multiple Auth Failures"; threshold:type both, track by_src, count 10, seconds 60; classtype:attempted-user; sid:2000011; rev:2;)

# SQL Injection Detection (sqlmap)
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP SQL Injection UNION"; flow:to_server,established; http.method; content:"GET"; http.uri; content:"UNION"; nocase; content:"SELECT"; nocase; distance:0; within:20; classtype:web-application-attack; sid:2000020; rev:2;)
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP SQLi Boolean Based"; flow:to_server,established; http.uri; content:"OR%201%3D1"; nocase; classtype:web-application-attack; sid:2000021; rev:3;)
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP SQLi Boolean Unencoded"; flow:to_server,established; http.uri; content:"OR 1=1"; nocase; classtype:web-application-attack; sid:2000025; rev:1;)
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP SQLi Time Based SLEEP"; flow:to_server,established; http.uri; content:"SLEEP%28"; nocase; classtype:web-application-attack; sid:2000022; rev:3;)
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP SQLi Time Unencoded"; flow:to_server,established; http.uri; content:"SLEEP("; nocase; classtype:web-application-attack; sid:2000026; rev:1;)
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP sqlmap User-Agent"; flow:to_server,established; http.user_agent; content:"sqlmap"; classtype:web-application-attack; sid:2000023; rev:2;)

# Slowloris DDoS Detection
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT Slowloris DDoS Connection"; flow:to_server,established; threshold:type both, track by_dst, count 200, seconds 30; classtype:denial-of-service; sid:2000030; rev:2;)

# FTP Brute-force
alert tcp any any -> $FTP_SERVERS $FTP_PORTS (msg:"ARCHIVIRT FTP Auth Brute-force"; flow:to_server,established; content:"PASS"; threshold:type threshold, track by_src, count 5, seconds 30; classtype:attempted-user; sid:2000040; rev:2;)

# -- IPS DROP rules (actives si ids_mode=ips) --
{% if ids_mode | default('ids') == 'ips' %}
drop tcp any any -> $HOME_NET any (msg:"ARCHIVIRT IPS DROP Nmap SYN"; flags:S,12; threshold:type threshold, track by_src, count 50, seconds 2; sid:3000001; rev:1;)
drop tcp any any -> $HOME_NET 22 (msg:"ARCHIVIRT IPS DROP SSH Brute"; flow:to_server,established; content:"SSH"; threshold:type both, track by_src, count 10, seconds 30; sid:3000010; rev:1;)
drop tcp any any -> $HOME_NET 80 (msg:"ARCHIVIRT IPS DROP SQLi UNION"; content:"UNION%20SELECT"; sid:3000020; rev:1;)
drop tcp any any -> $HOME_NET 80 (msg:"ARCHIVIRT IPS DROP sqlmap"; content:"sqlmap"; sid:3000021; rev:1;)
drop tcp any any -> $HOME_NET 80 (msg:"ARCHIVIRT IPS DROP Slowloris"; flow:to_server,established; content:"GET"; threshold:type both, track by_dst, count 200, seconds 30; sid:3000030; rev:1;)
{% endif %}
# SMB Scan/Exploitation
alert smb any any -> $HOME_NET $SMB_PORTS (msg:"ARCHIVIRT SMB Scan Detected"; threshold:type threshold, track by_src, count 5, seconds 10; classtype:network-scan; sid:2000050; rev:2;)

