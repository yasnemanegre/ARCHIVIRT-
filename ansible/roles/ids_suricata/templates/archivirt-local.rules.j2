# ARCHIVIRT Local Suricata 6 Rules - ASCII only
# Port Scan Detection
alert tcp any any -> $HOME_NET any (msg:"ARCHIVIRT Nmap SYN Scan"; flags:S; threshold:type threshold, track by_src, count 20, seconds 2; classtype:network-scan; sid:2000001; rev:5;)
alert tcp any any -> $HOME_NET any (msg:"ARCHIVIRT Nmap NULL Scan"; flags:0; sid:2000002; rev:2;)
alert tcp any any -> $HOME_NET any (msg:"ARCHIVIRT Nmap FIN Scan"; flags:F; sid:2000003; rev:2;)
alert tcp any any -> $HOME_NET any (msg:"ARCHIVIRT Nmap XMAS Scan"; flags:FPU; sid:2000004; rev:2;)
# SSH Brute-force Detection
alert tcp any any -> $SSH_SERVERS $SSH_PORTS (msg:"ARCHIVIRT SSH Brute-force"; threshold:type both, track by_src, count 5, seconds 30; classtype:attempted-user; sid:2000010; rev:3;)
# SQL Injection Detection
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP SQLi UNION"; flow:to_server,established; http.uri; content:"UNION"; nocase; classtype:web-application-attack; sid:2000020; rev:3;)
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP SQLi Boolean"; flow:to_server,established; http.uri; content:"OR%201%3D1"; nocase; classtype:web-application-attack; sid:2000021; rev:3;)
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP SQLi SLEEP"; flow:to_server,established; http.uri; content:"SLEEP%28"; nocase; classtype:web-application-attack; sid:2000022; rev:3;)
alert http any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT HTTP sqlmap UA"; flow:to_server,established; http.user_agent; content:"sqlmap"; classtype:web-application-attack; sid:2000023; rev:2;)
# DDoS Detection
alert tcp any any -> $HTTP_SERVERS $HTTP_PORTS (msg:"ARCHIVIRT DDoS Connection"; flags:S; threshold:type both, track by_dst, count 100, seconds 10; classtype:denial-of-service; sid:2000030; rev:5;)
# FTP Detection
alert tcp any any -> $FTP_SERVERS $FTP_PORTS (msg:"ARCHIVIRT FTP Brute-force"; threshold:type threshold, track by_src, count 5, seconds 30; classtype:attempted-user; sid:2000040; rev:4;)
# SMB Detection
alert tcp any any -> $HOME_NET 445 (msg:"ARCHIVIRT SMB Scan"; threshold:type threshold, track by_src, count 5, seconds 10; classtype:network-scan; sid:2000050; rev:5;)
